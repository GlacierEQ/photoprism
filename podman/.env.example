# PhotoPrism Environment Variables for Podman Deployment

# Admin user credentials
PHOTOPRISM_ADMIN_USER=admin
PHOTOPRISM_ADMIN_PASSWORD=admin

# Site configuration
PHOTOPRISM_SITE_URL=http://localhost:2342
PHOTOPRISM_SITE_TITLE=PhotoPrism
PHOTOPRISM_SITE_CAPTION="Browse Your Life"
PHOTOPRISM_SITE_DESCRIPTION=""
PHOTOPRISM_SITE_AUTHOR=""

# Database credentials
MYSQL_PASSWORD=photoprism
MYSQL_ROOT_PASSWORD=photoprism_root

# TensorFlow AI model for image classification
PHOTOPRISM_TENSORFLOW_OFF=false

# Face recognition settings
PHOTOPRISM_FACE_RECOGNITION=true
BRAINS_SERVER_KEY=please-change-this-key

# File upload settings
PHOTOPRISM_UPLOAD_NSFW=true
PHOTOPRISM_DETECT_NSFW=false

# Logging
PHOTOPRISM_LOG_LEVEL=info

# Performance settings
PHOTOPRISM_WORKERS=2
PHOTOPRISM_WAKEUP_INTERVAL=900
PHOTOPRISM_AUTO_INDEX=300
PHOTOPRISM_AUTO_IMPORT=300
