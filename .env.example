#========================================
# PhotoPrism2 Environment Configuration
#========================================
# Copy this file to .env.docker and edit as needed

# Basic Configuration
PHOTOPRISM_PORT=2342
PHOTOPRISM_SITE_URL=http://localhost:2342/
PHOTOPRISM_ADMIN_USER=admin
# Password is stored in docker/secrets/photoprism_admin_password.txt

# Database Configuration
MYSQL_DATABASE=photoprism
MYSQL_USER=photoprism
# Database passwords are stored in docker/secrets directory

# Resource Limits
CPU_LIMIT=2
MEMORY_LIMIT=2G
CPU_RESERVE=0.5
MEMORY_RESERVE=512M

# Logging
LOG_LEVEL=INFO
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Time Zone
TZ=UTC

# Build Configuration
BUILD_MODE=production
DOCKER_IMAGE_NAME=photoprism2
DOCKER_IMAGE_TAG=latest

# Optional Features
# Uncomment to enable
#PHOTOPRISM_EXPERIMENTAL=true
#PHOTOPRISM_BRAINS=true
